[Unit]
Description=Telegram bridge for Codex CLI
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/codexlav/bot
EnvironmentFile=%h/codexlav/.env
EnvironmentFile=-%h/.config/context7.env
ExecStart=/usr/bin/python3 %h/codexlav/bot/bot.py
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
